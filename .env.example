# .env.example
# Copy this file to .env.local and fill in the actual values from your team lead
# DO NOT commit .env.local to git

MONGODB_URI=your_mongodb_connection_string_here
JWT_SECRET=your_jwt_secret_here

# Canonical site URL (required for Instagram posting; use www subdomain)
# Instagram Graph API fetches the image from this URL – must be publicly reachable.
NEXT_PUBLIC_SITE_URL=https://www.chickenloop.com

# Stripe (payments / boosts)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
